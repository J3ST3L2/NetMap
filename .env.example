# Required for live LibreNMS mode
LIBRENMS_URL=https://librenms.company.local
LIBRENMS_TOKEN=replace_with_librenms_api_token

# true = always use fake demo data
# false = always require LibreNMS
# auto = use LibreNMS when configured, otherwise demo data
MOCK_MODE=auto

# Web app bind
PORT=8088

# Set true if LibreNMS uses an internal/self-signed certificate.
ALLOW_SELF_SIGNED_LIBRENMS=false

# Dashboard labels
TOPOLOGY_TITLE=DGE Sophos Enclave
TOPOLOGY_SUBTITLE=UXG edge, Sophos server-front, monitored by LibreNMS

# Comma-separated matching hints used to classify devices from LibreNMS.
EDGE_DEVICE_MATCH=uxg,unifi uxg,gateway,edge
CORE_SWITCH_MATCH=core,switch 1,switch1,main switch,agg
SERVER_FIREWALL_MATCH=sophos,enclave,firewall
SERVER_MATCH=librenms,server,vmware,proxmox,esxi,nas,hyper-v
EXCLUDE_DEVICE_MATCH=
