# Required
LIBRENMS_URL=https://librenms.company.local
LIBRENMS_TOKEN=replace_with_librenms_api_token

# Web app bind
PORT=8088

# Set true if LibreNMS uses an internal/self-signed certificate.
ALLOW_SELF_SIGNED_LIBRENMS=false

# Comma-separated matching hints used to place devices on the first render.
# Adjust these to your real LibreNMS hostnames/display names.
EDGE_DEVICE_MATCH=uxg,unifi uxg,gateway
CORE_SWITCH_MATCH=core,switch 1,switch1,main switch
SERVER_FIREWALL_MATCH=sophos,enclave
SERVER_MATCH=librenms,server,vmware,proxmox,esxi,nas

# Optional: comma-separated regex-ish text to exclude from topology.
# Example: EXCLUDE_DEVICE_MATCH=printer,camera,phone
EXCLUDE_DEVICE_MATCH=
